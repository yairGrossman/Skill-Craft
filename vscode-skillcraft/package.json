{
  "name": "vscode-skillcraft",
  "displayName": "Skill Craft Language",
  "description": "Syntax highlighting, IntelliSense autocomplete, and hover docs for the Skill Craft language (.skillc, .skillcm)",
  "version": "0.2.0",
  "publisher": "skillcraft",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:skillcraft"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "skillcraft",
        "aliases": [
          "Skill Craft",
          "skillcraft"
        ],
        "extensions": [
          ".skillc",
          ".skillcm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "skillcraft",
        "scopeName": "source.skillcraft",
        "path": "./syntaxes/skillcraft.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "skillcraft",
        "path": "./snippets/skillcraft.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0"
  }
}
